rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // --- Validation Helpers ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'name', 'role']) &&
             data.keys().size() == 4 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             data.name is string && data.name.size() <= 100 &&
             data.role in ['employee', 'hr'];
    }

    function isValidSession(data) {
      return data.keys().hasAll(['userId', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time &&
             ( !data.keys().hasAny(['riskLevel']) || data.riskLevel is number ) &&
             ( !data.keys().hasAny(['primaryEmotion']) || data.primaryEmotion is string ) &&
             ( !data.keys().hasAny(['summary']) || data.summary is string ) &&
             ( !data.keys().hasAny(['topicTags']) || (data.topicTags is list && data.topicTags.size() <= 10) );
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'content', 'timestamp']) &&
             data.keys().size() == 3 &&
             data.role in ['user', 'model'] &&
             data.content is string && data.content.size() <= 5000 &&
             data.timestamp == request.time;
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name']);
    }

    // Sessions
    match /sessions/{sessionId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidSession(incoming());
      allow update: if isOwner(existing().userId) && isValidSession(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['summary', 'riskLevel', 'primaryEmotion', 'topicTags']);
      allow delete: if isOwner(existing().userId);

      // Embedded messages subcollection
      match /messages/{messageId} {
        allow get, list: if isOwner(get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId);
        allow create: if isOwner(get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId) && isValidMessage(incoming());
      }
    }
  }
}
